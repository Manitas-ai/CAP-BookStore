{
  "name": "book-store",
  "version": "1.0.0",
  "description": "SAP Book-Store – Learning POC",
  "scripts": {
    "start": "cds deploy --to sqlite && cds serve",
    "watch": "cds watch"
  },
  "dependencies": {
    "express": "^4",
    "@sap/cds": "^8",
    "@cap-js/sqlite": "^1"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": { "url": "bookstore.db" }
      },
      "auth": {
        "kind": "mocked",
        "users": {
          "admin": {
            "password": "Admin123",
            "roles": ["admin"]
          },
          "*": true
        }
      }
    },
    "server": {
      "cors": true
    }
  }
}
